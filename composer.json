{
  "require": {
    "php": ">=8.2",
    "flightphp/core": "^3.10",
    "phar-io/manifest": "^2.0",
    "leafs/session": "^2.0",
    "filp/whoops": "^2.15",
    "megacreativo/cedulave-api": "^1.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app",
      "Views\\": "views"
    },
    "classmap": [
      "app/App.php"
    ],
    "files": [
      "app/utils.php"
    ]
  },
  "scripts": {
    "dev:win": "start php -S localhost:80",
    "deploy": "composer install --no-dev -o & composer archive",
    "migrate:fresh": "php app/commands/migrate-fresh.php",
    "post-install-cmd": [
      "php -r \"if (!file_exists('.env.php')) copy('.env.dist.php', '.env.php');\""
    ]
  },
  "require-dev": {
    "symfony/var-dumper": "^7.1"
  },
  "archive": {
    "name": "HAJU",
    "exclude": [
      ".phpunit.cache",
      "tests",
      ".editorconfig",
      ".env.php",
      ".gitignore",
      ".git",
      "haju.sublime-*",
      "phpunit.xml",
      "README.md",
      "composer.*",
      "node_modules",
      "biome.json",
      "package.json",
      "pnpm-*",
      "*.db",
      "*.sqlite",
      "*.todo"
    ]
  }
}
