{
	"name": "haju/haju",
	"description": "Sistema Automatizado para el Registro y Control de Entrada y Salida de Medicamentos en el Hospital General Municipal Antonio José Uzcátegui",
	"authors": [
		{
			"name": "Franyer",
			"email": "franyeradriansanchez@gmail.com"
		}
	],
	"readme": "README.md",
	"type": "project",
	"autoload": {
		"psr-4": {
			"App\\": "src"
		}
	},
	"require": {
		"php": "^8.2",
		"mikecao/flight": "^v2.0.1",
		"franyer/sparrow": "^v1.0.0",
		"symfony/dotenv": "^v6.2.8"
	},
	"require-dev": {
		"phpunit/phpunit": "10.1.3",
		"phpstan/phpstan": "1.10.15",
		"phpstan/extension-installer": "1.3.1"
	},
	"config": {
		"allow-plugins": {
			"phpstan/extension-installer": true
		}
	},
	"scripts": {
		"lint": "phpstan --configuration=phpstan.neon --no-progress",
		"test": "phpunit"
	},
	"license": "proprietary"
}
